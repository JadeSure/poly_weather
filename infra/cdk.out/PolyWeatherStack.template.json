  "PolyWeatherInstance5E3A4156": {
   "Type": "AWS::EC2::Instance",
   "Properties": {
    "AvailabilityZone": "ap-southeast-2a",
    "BlockDeviceMappings": [
     {
      "DeviceName": "/dev/xvda",
      "Ebs": {
       "DeleteOnTermination": true,
       "Encrypted": true,
       "VolumeSize": 20,
       "VolumeType": "gp3"
      }
     },
     {
      "DeviceName": "/dev/xvdf",
      "Ebs": {
